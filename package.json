{
  "name": "copilot-agent-flow-studio",
  "displayName": "Agent Flow Studio",
  "description": "Visual manager for GitHub Copilot agent pipelines.",
  "version": "0.0.27",
  "publisher": "marcmalerei",
  "icon": "media/icon.png",
  "license": "MIT",
  "galleryBanner": {
    "color": "#0F1216",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcmalerei/agent-flow.git"
  },
  "bugs": {
    "url": "https://github.com/marcmalerei/agent-flow/issues"
  },
  "homepage": "https://github.com/marcmalerei/agent-flow#readme",
  "keywords": [
    "agent",
    "copilot",
    "pipeline",
    "workflow",
    "visualization"
  ],
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCommand:agentflow.openPipeline",
    "onCommand:agentflow.scanWorkspace",
    "onCommand:agentflow.generateFiles",
    "onCommand:agentflow.validatePipeline",
    "onCommand:agentflow.createDefaultPipeline",
    "onCommand:agentflow.playDemoActivity",
    "onLanguageModelTool:agentflow_select_node",
    "onLanguageModelTool:agentflow_report_activity",
    "onLanguageModelTool:agentflow_complete_node"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Agent Flow",
      "properties": {
        "agentflow.flow.layout": {
          "type": "string",
          "default": "compact",
          "enum": [
            "vertical",
            "horizontal",
            "typeColumns",
            "compact"
          ],
          "enumDescriptions": [
            "Arrange nodes in top-to-bottom dependency layers.",
            "Arrange nodes in left-to-right dependency layers.",
            "Arrange nodes in wrapped columns by node type with collision-free spacing.",
            "Automatically group connected workflow components into compact collision-free shelves for large graphs."
          ],
          "description": "Controls how Agent Flow automatically arranges nodes in the flow view. Layout is derived from Markdown files and is not persisted to JSON."
        },
        "agentflow.activity.copilotDebugLogs.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable best-effort import of local GitHub Copilot debug-log events into the Agent Flow activity timeline when Copilot file logging is enabled."
        },
        "agentflow.activity.copilotDebugLogs.dataPath": {
          "type": "string",
          "default": "",
          "description": "Optional folder containing Copilot debug log JSON or JSONL files. Leave empty to auto-detect VS Code Copilot debug-log folders."
        },
        "agentflow.activity.sources.filesystem": {
          "type": "boolean",
          "default": true,
          "description": "Enable filesystem write activity from .github Agent Flow pipeline file watchers."
        },
        "agentflow.activity.sources.vscodeDocuments": {
          "type": "boolean",
          "default": true,
          "description": "Enable read/write activity from VS Code document open and save events for .github Agent Flow files."
        },
        "agentflow.activity.sources.agentFlowTools": {
          "type": "boolean",
          "default": true,
          "description": "Enable Agent Flow language model activity tools that agents can call to report progress."
        }
      }
    },
    "commands": [
      {
        "command": "agentflow.openPipeline",
        "title": "Open Pipeline",
        "category": "Agent Flow"
      },
      {
        "command": "agentflow.scanWorkspace",
        "title": "Scan Workspace",
        "category": "Agent Flow"
      },
      {
        "command": "agentflow.generateFiles",
        "title": "Generate Files",
        "category": "Agent Flow"
      },
      {
        "command": "agentflow.validatePipeline",
        "title": "Validate Pipeline",
        "category": "Agent Flow"
      },
      {
        "command": "agentflow.createDefaultPipeline",
        "title": "Create Default Pipeline",
        "category": "Agent Flow"
      },
      {
        "command": "agentflow.playDemoActivity",
        "title": "Play Demo Activity",
        "category": "Agent Flow"
      },
      {
        "command": "agentflow.copyDebugSnapshot",
        "title": "Copy Debug Snapshot",
        "category": "Agent Flow"
      }
    ],
    "languageModelTools": [
      {
        "name": "agentflow_select_node",
        "displayName": "Select Agent Flow Node",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "agentflowSelectNode",
        "icon": "$(graph)",
        "userDescription": "Select a node in the Agent Flow activity context.",
        "modelDescription": "Use this tool when work in the current chat is about a specific Agent Flow node. Provide only the node label, id, or backing file path. Do not include prompt contents.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "node": {
              "type": "string",
              "description": "Agent Flow node id, label, or backing file path."
            },
            "sessionId": {
              "type": "string",
              "description": "Optional activity session id."
            }
          },
          "required": [
            "node"
          ]
        }
      },
      {
        "name": "agentflow_report_activity",
        "displayName": "Report Agent Flow Activity",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "agentflowReportActivity",
        "icon": "$(pulse)",
        "userDescription": "Report sanitized progress for an Agent Flow node.",
        "modelDescription": "Use this tool to report sanitized node progress such as queued, started, thinking, tool, file, artifact, handoff, completed, failed, or cancelled. Include short summaries only. Do not include raw prompts, secrets, or full file contents.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string"
            },
            "node": {
              "type": "string",
              "description": "Node id, label, or file path."
            },
            "nodeFile": {
              "type": "string"
            },
            "targetNode": {
              "type": "string"
            },
            "phase": {
              "type": "string",
              "enum": [
                "queued",
                "started",
                "thinking",
                "tool",
                "file",
                "artifact",
                "handoff",
                "completed",
                "failed",
                "cancelled"
              ]
            },
            "summary": {
              "type": "string"
            },
            "toolName": {
              "type": "string"
            },
            "artifactPath": {
              "type": "string"
            },
            "durationMs": {
              "type": "number"
            },
            "tokenEstimate": {
              "type": "number"
            },
            "severity": {
              "type": "string",
              "enum": [
                "info",
                "warning",
                "error"
              ]
            }
          }
        }
      },
      {
        "name": "agentflow_complete_node",
        "displayName": "Complete Agent Flow Node",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "agentflowCompleteNode",
        "icon": "$(pass)",
        "userDescription": "Mark an Agent Flow node as completed or failed.",
        "modelDescription": "Use this tool when work for a specific Agent Flow node is done or failed. Include a short sanitized summary and whether it failed.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": {
              "type": "string"
            },
            "node": {
              "type": "string"
            },
            "failed": {
              "type": "boolean"
            },
            "summary": {
              "type": "string"
            },
            "durationMs": {
              "type": "number"
            }
          },
          "required": [
            "node"
          ]
        }
      }
    ],
    "submenus": [
      {
        "id": "agentflow.context",
        "label": "Agent Flow"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "agentflow.context",
          "when": "resourceScheme == file && resourcePath =~ /[\\\\\\/]\\.github[\\\\\\/].*\\.md$/",
          "group": "navigation@80"
        }
      ],
      "agentflow.context": [
        {
          "command": "agentflow.openPipeline",
          "group": "1_pipeline@1"
        },
        {
          "command": "agentflow.scanWorkspace",
          "group": "1_pipeline@2"
        },
        {
          "command": "agentflow.validatePipeline",
          "group": "2_checks@1"
        },
        {
          "command": "agentflow.generateFiles",
          "group": "3_generation@1"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "dev:webview:example": "vite --config vite.webview.dev.config.mts --host 127.0.0.1",
    "build:webview": "vite build --config vite.webview.config.mts",
    "build": "npm run compile && npm run build:webview",
    "icon": "node scripts/generate-marketplace-icon.mjs",
    "capture:preview": "node scripts/capture-preview-gif.mjs",
    "package:vsix": "vsce package --out copilot-agent-flow-studio.vsix",
    "package:marketplace": "npm run build && npm run package:vsix",
    "prepare": "husky",
    "compile:smoke": "tsc -p tsconfig.smoke.json",
    "test:smoke": "npm run compile && npm run build:webview && npm run compile:smoke && node scripts/run-smoke-tests.mjs",
    "test": "vitest run --config vitest.config.mts",
    "check": "npm run compile && npm run test"
  },
  "devDependencies": {
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-bold": "^3.26.1",
    "@tiptap/extension-bullet-list": "^3.26.1",
    "@tiptap/extension-code": "^3.26.1",
    "@tiptap/extension-code-block": "^3.26.1",
    "@tiptap/extension-document": "^3.26.1",
    "@tiptap/extension-heading": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-list": "^3.26.1",
    "@tiptap/extension-list-item": "^3.26.1",
    "@tiptap/extension-paragraph": "^3.26.1",
    "@tiptap/extension-text": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.120.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vscode/codicons": "^0.0.45",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "@xyflow/react": "^12.6.4",
    "husky": "^9.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
